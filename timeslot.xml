<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M-v1_1.xsd">
    <Object ObjectType="MODefinition">
		<Name>Timeslot</Name>
		<Description1><![CDATA[Timeslot is an instance of a schedule]]></Description1>
		<ObjectID>28182</ObjectID>
		<ObjectURN>urn:oma:lwm2m:x:28182:0.2</ObjectURN>
		<LWM2MVersion>1.1</LWM2MVersion>
		<ObjectVersion>0.2</ObjectVersion>
		<MultipleInstances>Multiple</MultipleInstances>
		<Mandatory>Optional</Mandatory>
		<Resources>
			<Item ID="1">
				<Name>start</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Time</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Start time in seconds from UNIX epoch.]]></Description>
			</Item>
			<Item ID="3">
				<Name>adjusted_stop</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Time</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units>s</Units>
				<Description><![CDATA[Timeslot stop time after adjustment (same as planned_stop if not adjusted)]]></Description>
			</Item>
			<Item ID="4">
				<Name>state</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[TSS state]]></Description>
			</Item>
			<Item ID="6">
				<Name>initial_source</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[How start and planned_stop were set. ]]></Description>
			</Item>
			<Item ID="7">
				<Name>adjustment_source</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[How adjusted_stop was set. Same values as for initial_source. ]]></Description>
			</Item>
			<Item ID="8">
				<Name>pre_offset</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Magic cookie used by backend. Copied over from schedule config.]]></Description>
			</Item>
			<Item ID="9">
				<Name>actuator</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Corresponding actuator id (zero-indexed).]]></Description>
			</Item>
			<Item ID="32">
				<Name>adjust_duration</Name>
				<Operations>E</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type></Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Adjust duration of planned or running timeslot. Only has effect on timeslots in states SCHEDULED, WILL_START, RUNNING (has no effect on timeslots in all other states). Takes two arguments:
  0: integer: adjustment source. Updates the adjustment_source field.
     See initial_source above for list of available values. Use value 2 if not sure.
  1: integer: new duration in seconds.
Uses OMA format. Example usage with bnw_cli:
  $ poetry run bnw ipso exc "$DEVICE" timeslot/0/set_duration "as=[0='10',1='120']"
]]></Description>
			</Item>
		</Resources>
		<Description2><![CDATA[]]></Description2>
	</Object>
</LWM2M>
