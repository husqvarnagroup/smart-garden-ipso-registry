<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M-v1_1.xsd">
    <Object ObjectType="MODefinition">
        <Name>Wake on Radio</Name>
        <Description1><![CDATA[Wake on Radio]]></Description1>
        <ObjectID>28184</ObjectID>
        <ObjectURN>urn:oma:lwm2m:x:28184:1.0</ObjectURN>
        <LWM2MVersion>1.1</LWM2MVersion>
        <ObjectVersion>1.0</ObjectVersion>
        <MultipleInstances>Single</MultipleInstances>
        <Mandatory>Optional</Mandatory>
        <Resources>
            <Item ID="0">
                <Name>wakeup_channel</Name>
                <Operations>R</Operations>
                <MultipleInstances>Single</MultipleInstances>
                <Mandatory>Mandatory</Mandatory>
                <Type>Integer</Type>
                <RangeEnumeration>1..30</RangeEnumeration>
                <Units></Units>
                <Description><![CDATA[Wakeup channel selected by the device during inclusion. The channel must be in the range of 1 to 30 and must not be the same as the data and sync channels (default: 3, 12, 20, 29).]]></Description>
