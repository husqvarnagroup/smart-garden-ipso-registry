<?xml version="1.0" encoding="utf-8"?>
<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M.xsd">
	<Object ObjectType="MODefinition">
		<Name>Includable Device</Name>
		<Description1><![CDATA[Represent a device that can be included into the network of the gateway]]></Description1>
		<ObjectID>28170</ObjectID>
		<ObjectURN>urn:oma:lwm2m:x:28170:0.2</ObjectURN>
		<LWM2MVersion>1.0</LWM2MVersion>
		<ObjectVersion>0.2</ObjectVersion>
		<MultipleInstances>Multiple</MultipleInstances>
		<Mandatory>Optional</Mandatory>
		<Resources>
			<Item ID="1">
				<Name>identifier</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Examples:
3034F8EE90126D4000000033]]></Description>
			</Item>
			<Item ID="2">
				<Name>protocol</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration>1..2</RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[1=lwm2m
2=lemonbeat]]></Description>
			</Item>
			<Item ID="5">
				<Name>include</Name>
				<Operations>E</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type></Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Start inclusion (semantics dependent on protocol)

lwm2m: allow bootstrap & registration (inclusion_allowed = True)

lemonbeat: start inclusion process (inclusion_allowed = True & inclusion_started = True)
]]></Description>
			</Item>
			
			<Item ID="7">
				<Name>inclusion_started</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Boolean</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Has the device started the inclusion process?]]></Description>
			</Item>
			<Item ID="8">
				<Name>inclusion_completed</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Boolean</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Has the device completed the inclusion process and is now part of gateway network?]]></Description>
			</Item>
			<Item ID="9">
				<Name>inclusion_error</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration>0...</RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[0=no error
1=inclusion start failure

further error codes might be protocol specific / dependent

lwm2m:
1: device could not be whitelisted]]></Description>
			</Item>
			
		</Resources>
		<Description2 />
	</Object>
</LWM2M>
