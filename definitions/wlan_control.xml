<LWM2M xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.openmobilealliance.org/tech/profiles/LWM2M.xsd">
	<Object ObjectType="MODefinition">
		<Name>WLAN Control</Name>
		<Description1><![CDATA[WLAN configuration support]]></Description1>
		<ObjectID>28176</ObjectID>
		<ObjectURN>urn:oma:lwm2m:x:28176</ObjectURN>
		<LWM2MVersion>1.1</LWM2MVersion>
		<ObjectVersion>1.0</ObjectVersion>
		<MultipleInstances>Single</MultipleInstances>
		<Mandatory>Optional</Mandatory>
		<Resources>
			<Item ID="1">
				<Name>Scan SSIDs</Name>
				<Operations>E</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Integer</Type>
				<RangeEnumeration>0..600</RangeEnumeration>
				<Units>s</Units>
				<Description><![CDATA[Scans SSIDs during the specified time period.]]></Description>
			</Item>
			<Item ID="2">
				<Name>Scan Active</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>Boolean</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Indicates if scanning is active or not.]]></Description>
			</Item>
			<Item ID="3">
				<Name>Configure SSID</Name>
				<Operations>E</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Mandatory</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[<ssid> <wpa_password_hash> <is_hidden_ssid>
ssid: name of the WLAN network to connect to
wpa_password_hash: 64-byte upper-case hex value, calculated as PBKDF2(HMAC−SHA1, passphrase, ssid, 4096, 256)
is_hidden_ssid: "true" if it is a hidden SSID, "false" if not]]></Description>
			</Item>
			<Item ID="4">
				<Name>Configured SSID</Name>
				<Operations>R</Operations>
				<MultipleInstances>Single</MultipleInstances>
				<Mandatory>Optional</Mandatory>
				<Type>String</Type>
				<RangeEnumeration></RangeEnumeration>
				<Units></Units>
				<Description><![CDATA[Network name of the currently configured WLAN.]]></Description>
			</Item>
		</Resources>
		<Description2 />
	</Object>
</LWM2M>
